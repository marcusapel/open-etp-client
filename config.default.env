#
# The following fields are default values for your application environment and
# can be overwritten by setting them in a config.user.env file as advertised in
# the README.md.
################################################################################


#-------------------------------------------------------------------------------
# Remote docker images
RDMS_ETP_IMAGE=community.opengroup.org:5555/osdu/platform/domain-data-mgmt-services/reservoir/open-etp-server/open-etp-server-main:latest

# Use self build images by default
RDMS_REST_RUNTIME_IMAGE=osdu-reservoir-rest-api

#-------------------------------------------------------------------------------
# REST server config (this server)
# Environment variables used by server
# RDMS_REST_MAIN_URL : Base url for openAPI - "http://localhost"
# RDMS_REST_ROOT_PATH : local path inside url - "/Reservoir/v2"
RDMS_REST_ROOT_PATH="/Reservoir/v2"
# RDMS_REST_PORT : Port of openAPI - "8003"
RDMS_REST_PORT=8003
#  --- OpenAPI url is `${RDMS_REST_MAIN_URL}:${OPEN_API_PORT}${RDMS_REST_ROOT_PATH}` ---
OPEN_API_PORT=443

#-------------------------------------------------------------------------------
# Partitioning
# Partitions mode (single | multipartition)
RDMS_DATA_PARTITION_MODE=single
# Partition name for client testing
# RDMS_TEST_DATA_PARTITION_ID=test

# ETP
RDMS_AUTHENTICATION_KEY_BASE=0000000-0000-0000-0000-000000000000
# Secret for ETP connection
RDMS_JWT_SECRET=osdu-rddms # pragma: allowlist secret

# RDMS_ETP_PROTOCOL websocket protocol "ws" or "wss"
# RDMS_ETP_HOST domain of etp server
# RDMS_ETP_PORT port of ETP server
# RDMS_ETP_PATH local path in ETP server url
#  --- ETP server url is `${RDMS_ETP_PROTOCOL}://${RDMS_ETP_HOST}:${RDMS_ETP_PORT}${RDMS_ETP_PATH}/` ---

# Use WebSockets as protocol
RDMS_ETP_PROTOCOL=ws
# docker based ETP server
# cannot use host.docker.internal because it's unknown on linux
RDMS_ETP_HOST=localhost
# ETP server port (default docker based ETP server)
RDMS_ETP_PORT=9004
# Data Path location on ETP server
RDMS_ETP_PATH=

# Local folder that contains data for ETP server
RDMS_HOST_DOCKER_MOUNT_RESQML_DATA_PATH=../../devops/data
# List of projects to import automatically in ETP server
RDMS_PROJECTS_TO_IMPORT_IN_EML=Volve_Demo_Horizons_Depth
